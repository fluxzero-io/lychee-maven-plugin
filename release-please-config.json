{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "maven",
  "packages": {
    ".": {
      "package-name": "lychee-maven-plugin",
      "include-v-in-tag": true,
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Fixes"
        },
        {
          "type": "security",
          "section": "Security"
        },
        {
          "type": "deps",
          "section": "Dependencies"
        },
        {
          "type": "chore",
          "section": "Chores",
          "hidden": true
        },
        {
          "type": "docs",
          "section": "Docs",
          "hidden": true
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": true
        }
      ]
    }
  }
}
